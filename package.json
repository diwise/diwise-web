{
  "scripts": {
    "build:css:legacy": "node ./node_modules/@tailwindcss/cli/dist/index.mjs -i ./internal/pkg/presentation/web/css/input.css -o ./assets/css/diwise.css",
    "build:css:v2": "node ./node_modules/@tailwindcss/cli/dist/index.mjs -i ./internal/pkg/presentation/webv2/css/input.css -o ./assets/css/diwise-v2.css",
