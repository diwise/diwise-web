package ui

import (
	"github.com/diwise/diwise-web/internal/pkg/presentation/webv2/components/shared/ui/calendar"
	"github.com/diwise/diwise-web/internal/pkg/presentation/webv2/components/shared/ui/dialog"
	"github.com/diwise/diwise-web/internal/pkg/presentation/webv2/components/shared/ui/input"
	"github.com/diwise/diwise-web/internal/pkg/presentation/webv2/components/shared/ui/label"
	"github.com/diwise/diwise-web/internal/pkg/presentation/webv2/components/shared/ui/popover"
	"github.com/diwise/diwise-web/internal/pkg/presentation/webv2/components/shared/ui/progress"
	"github.com/diwise/diwise-web/internal/pkg/presentation/webv2/components/shared/ui/selectbox"
	"github.com/diwise/diwise-web/internal/pkg/presentation/webv2/components/shared/ui/tagsinput"
)

// TemplUIScripts includes script tags for all currently installed templui components
// in this repository that ship JavaScript.
templ TemplUIScripts() {
	@input.Script()
	@label.Script()
	@popover.Script()
	@calendar.Script()
	@dialog.Script()
	@progress.Script()
	@selectbox.Script()
	@tagsinput.Script()
}
